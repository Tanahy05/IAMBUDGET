<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.chart.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.BudgetingAnalysis"
            prefHeight="600.0" prefWidth="800.0">
    <children>
        <VBox spacing="10" AnchorPane.topAnchor="10.0" AnchorPane.leftAnchor="10.0"
              AnchorPane.rightAnchor="10.0" AnchorPane.bottomAnchor="10.0">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- Header -->
            <HBox alignment="CENTER">
                <Text text="Budget &amp; Spending Analysis" styleClass="header-text">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Text>
            </HBox>

            <!-- Main Content in a SplitPane -->
            <SplitPane dividerPositions="0.4" VBox.vgrow="ALWAYS">
                <!-- Left Panel - Budget Setting -->
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Label text="Set Budget Categories" styleClass="section-header">
                        <font>
                            <Font name="System Bold" size="16.0"/>
                        </font>
                    </Label>

                    <!-- Budget Category Form -->
                    <GridPane hgap="10" vgap="10">
                        <padding>
                            <Insets top="10" right="0" bottom="10" left="0"/>
                        </padding>

                        <Label text="Category:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                        <ComboBox fx:id="categoryComboBox" promptText="Select Category"
                                  GridPane.columnIndex="1" GridPane.rowIndex="0" maxWidth="Infinity"/>

                        <Label text="Budget Amount:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                        <TextField fx:id="budgetAmountField" promptText="0.00"
                                   GridPane.columnIndex="1" GridPane.rowIndex="1"/>

                        <Label text="Time Period:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                        <ComboBox fx:id="timePeriodComboBox" promptText="Monthly"
                                  GridPane.columnIndex="1" GridPane.rowIndex="2" maxWidth="Infinity"/>

                        <Button fx:id="saveBudgetButton" text="Save Budget" onAction="#handleSaveBudget"
                                GridPane.columnIndex="1" GridPane.rowIndex="3" maxWidth="Infinity"/>

                        <columnConstraints>
                            <ColumnConstraints percentWidth="30"/>
                            <ColumnConstraints percentWidth="70"/>
                        </columnConstraints>
                    </GridPane>

                    <!-- Budget Categories List -->
                    <Label text="Your Budget Categories" styleClass="section-header">
                        <font>
                            <Font name="System Bold" size="16.0"/>
                        </font>
                    </Label>

                    <TableView fx:id="budgetCategoriesTable" VBox.vgrow="ALWAYS">
                        <columns>
                            <TableColumn fx:id="categoryNameColumn" text="Category" prefWidth="120"/>
                            <TableColumn fx:id="budgetAmountColumn" text="Budget Amount" prefWidth="120"/>
                            <TableColumn fx:id="timePeriodColumn" text="Period" prefWidth="80"/>
                            <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="60"/>
                        </columns>
                    </TableView>
                </VBox>

                <!-- Right Panel - Spending Analysis -->
                <VBox spacing="10">
                    <padding>
                        <Insets top="10" right="10" bottom="10" left="10"/>
                    </padding>

                    <Label text="Spending Analysis" styleClass="section-header">
                        <font>
                            <Font name="System Bold" size="16.0"/>
                        </font>
                    </Label>

                    <!-- Period Selection -->
                    <HBox spacing="10" alignment="CENTER_LEFT">
                        <Label text="Period:"/>
                        <ComboBox fx:id="analysisPeriodComboBox" promptText="This Month"
                                  onAction="#handleAnalysisPeriodChange"/>
                        <Button fx:id="refreshAnalysisButton" text="Refresh"
                                onAction="#handleRefreshAnalysis"/>
                    </HBox>

                    <!-- Budget Summary -->
                    <TitledPane text="Budget Summary" expanded="true">
                        <VBox spacing="5">
                            <GridPane hgap="10" vgap="5">
                                <Label text="Total Budget:" GridPane.columnIndex="0" GridPane.rowIndex="0"/>
                                <Region>
                                    <padding>
                                        <Insets top="0" right="0" bottom="0" left="0"/>
                                    </padding>
                                </Region>

                                <Label text="Total Spent:" GridPane.columnIndex="0" GridPane.rowIndex="1"/>
                                <Region>
                                    <padding>
                                        <Insets top="0" right="0" bottom="0" left="0"/>
                                    </padding>
                                </Region>

                                <Label text="Remaining:" GridPane.columnIndex="0" GridPane.rowIndex="2"/>
                                <Region>
                                    <padding>
                                        <Insets top="0" right="0" bottom="0" left="0"/>
                                    </padding>
                                </Region>

                                <columnConstraints>
                                    <ColumnConstraints percentWidth="40"/>
                                    <ColumnConstraints percentWidth="60"/>
                                </columnConstraints>
                            </GridPane>

                            <ProgressBar fx:id="budgetProgressBar" progress="0.0" maxWidth="Infinity"/>
                        </VBox>
                    </TitledPane>

                    <!-- Charts -->
                    <TabPane fx:id="chartTabPane" VBox.vgrow="ALWAYS">
                        <Tab text="Spending by Category" closable="false">
                            <PieChart fx:id="spendingPieChart"/>
                        </Tab>
                        <Tab text="Budget vs. Actual" closable="false">
                            <BarChart fx:id="budgetVsActualChart">
                                <xAxis>
                                    <CategoryAxis label="Categories"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Amount"/>
                                </yAxis>
                            </BarChart>
                        </Tab>
                        <Tab text="Spending Trend" closable="false">
                            <LineChart fx:id="spendingTrendChart">
                                <xAxis>
                                    <CategoryAxis label="Time"/>
                                </xAxis>
                                <yAxis>
                                    <NumberAxis label="Amount"/>
                                </yAxis>
                            </LineChart>
                        </Tab>
                    </TabPane>
                </VBox>
            </SplitPane>

            <!-- Bottom Action Buttons -->
            <HBox spacing="10" alignment="CENTER_RIGHT">
                <Button fx:id="exportButton" text="Export Report" onAction="#handleExportReport"/>
                <Button fx:id="dashboardButton" text="Back to Dashboard" onAction="#handleBackToDashboard"/>
            </HBox>
        </VBox>
    </children>
</AnchorPane>