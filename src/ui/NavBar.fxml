<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.text.*?>

<AnchorPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.NavBar"
            prefHeight="50.0">

    <HBox style="-fx-background-color: #2c3e50; -fx-padding: 10;"
          AnchorPane.leftAnchor="0" AnchorPane.rightAnchor="0" AnchorPane.topAnchor="0" AnchorPane.bottomAnchor="0"
          spacing="10">
        <Label text="Budget Manager" style="-fx-text-fill: white; -fx-font-size: 20; -fx-font-weight: bold;"/>
        <Region fx:id="spacer" HBox.hgrow="ALWAYS"/>
        <Button text="DahBoard" onAction="#showDashboard" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Add income" onAction="#showIncome" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Add Budgets" onAction="#showBudgets" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Reminders" onAction="#showReminders" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Expense Tracker" onAction="#showReports" style="-fx-background-color: #3498db; -fx-text-fill: white;"/>
        <Button text="Logout" onAction="#handleLogout" style="-fx-background-color: #e74c3c; -fx-text-fill: white;"/>
    </HBox>
</AnchorPane>
