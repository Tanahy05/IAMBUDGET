<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.*?>
<?import java.util.*?>
<?import javafx.scene.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.text.Text?>

<AnchorPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controller.IncomeTrackingController"
            prefHeight="600.0" prefWidth="800.0">

    <children>
        <!-- Main Content Container -->
        <VBox spacing="20.0" AnchorPane.topAnchor="0.0" AnchorPane.rightAnchor="0.0"
              AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0">

            <!-- Header -->
            <HBox alignment="CENTER" style="-fx-background-color: #4CAF50; -fx-padding: 15;">
                <Label text="Income Tracking" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="24.0"/>
                    </font>
                </Label>
            </HBox>

            <!-- Form Section -->
            <VBox spacing="15.0" style="-fx-padding: 20;">
                <Label text="Add Income" style="-fx-font-weight: bold; -fx-font-size: 18;">
                </Label>

                <!-- Income Source Input -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Income Source:" prefWidth="100.0"/>
                    <ComboBox fx:id="incomeSourceComboBox" prefWidth="200.0" promptText="Select or enter source" editable="true"/>
                </HBox>

                <!-- Amount Input -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Amount ($):" prefWidth="100.0"/>
                    <TextField fx:id="amountTextField" promptText="Enter amount" prefWidth="200.0"/>
                </HBox>

                <!-- Date Input -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Date:" prefWidth="100.0"/>
                    <DatePicker fx:id="datePicker" prefWidth="200.0"/>
                </HBox>

                <!-- Description Input -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Description:" prefWidth="100.0"/>
                    <TextField fx:id="descriptionTextField" promptText="Optional description" prefWidth="350.0"/>
                </HBox>

                <!-- Recurring Option -->
                <HBox spacing="10.0" alignment="CENTER_LEFT">
                    <Label text="Recurring:" prefWidth="100.0"/>
                    <CheckBox fx:id="recurringCheckBox"/>
                    <ComboBox fx:id="recurringPeriodComboBox" prefWidth="150.0" promptText="Select period"/>
                </HBox>

                <!-- Action Buttons -->
                <HBox spacing="10.0" alignment="CENTER_LEFT" style="-fx-padding: 10 0 0 0;">
                    <Button fx:id="saveButton" text="Save Income" style="-fx-background-color: #4CAF50; -fx-text-fill: white;"
                            onAction="#handleSaveIncome"/>
                    <Button fx:id="clearButton" text="Clear Form" style="-fx-background-color: #f0f0f0;"
                            onAction="#handleClearForm"/>
                </HBox>
            </VBox>

            <!-- Income Listing Section -->
            <VBox VBox.vgrow="ALWAYS" style="-fx-padding: 0 20 20 20;">
                <Label text="Recent Income Entries" style="-fx-font-weight: bold; -fx-font-size: 18;"/>

                <TableView fx:id="incomeTableView" VBox.vgrow="ALWAYS">
                    <columns>
                        <TableColumn fx:id="dateColumn" text="Date" prefWidth="100.0"/>
                        <TableColumn fx:id="sourceColumn" text="Source" prefWidth="150.0"/>
                        <TableColumn fx:id="amountColumn" text="Amount" prefWidth="100.0"/>
                        <TableColumn fx:id="descriptionColumn" text="Description" prefWidth="250.0"/>
                        <TableColumn fx:id="recurringColumn" text="Recurring" prefWidth="100.0"/>
                        <TableColumn fx:id="actionsColumn" text="Actions" prefWidth="80.0"/>
                    </columns>
                </TableView>

                <!-- Summary Section -->
                <HBox alignment="CENTER_RIGHT" spacing="20.0" style="-fx-padding: 10 0 0 0;">
                    <Label text="Total Income:" style="-fx-font-weight: bold;"/>
                    <Region>
                        <padding>
                            <Insets top="0" right="0" bottom="0" left="0"/>
                        </padding>
                    </Region>

                </HBox>
            </VBox>

            <!-- Status Bar -->
            <HBox alignment="CENTER_LEFT" style="-fx-background-color: #f0f0f0; -fx-padding: 5 20;">
                <Label fx:id="statusLabel" text="Ready to add income entries"/>
                <HBox HBox.hgrow="ALWAYS" alignment="CENTER_RIGHT">
                    <Button fx:id="dashboardButton" text="Go to Dashboard" onAction="#handleGoToDashboard"/>
                </HBox>
            </HBox>
        </VBox>
    </children>
</AnchorPane>